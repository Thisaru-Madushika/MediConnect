<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6FBFF"
    tools:context=".DoctorProfileActivity">

    <!-- Header -->
    <ImageView
        android:id="@+id/iv_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_rounded"
        android:backgroundTint="#FFFFFF"
        android:padding="10dp"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#000000" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Doctor Profile"
        android:textColor="#111827"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/iv_back"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/iv_back" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/btn_confirm_selection"
        app:layout_constraintTop_toBottomOf="@id/tv_title">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <!-- Doctor Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_doctor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="22dp"
                android:layout_marginTop="4dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/iv_doctor"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/bg_rounded"
                        android:backgroundTint="#EFF6FF"
                        android:padding="12dp"
                        android:src="@drawable/ic_user"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#2563EB" />

                    <TextView
                        android:id="@+id/tv_dr_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Dr. Dhammika Weerakoon"
                        android:textColor="#111827"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/iv_doctor"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_specialty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Cardiologist"
                        android:textColor="#004A99"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="@id/tv_dr_name"
                        app:layout_constraintTop_toBottomOf="@id/tv_dr_name" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_rounded"
                        android:backgroundTint="#FFF1F2"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        app:layout_constraintStart_toStartOf="@id/tv_specialty"
                        app:layout_constraintTop_toBottomOf="@id/tv_specialty">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ 4.9 (120 Reviews)"
                            android:textColor="#E11D48"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal"
                        app:layout_constraintTop_toBottomOf="@id/iv_doctor">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EXPERIENCE" android:textColor="#374151" android:textSize="12sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="8 Years" android:textColor="#111827" android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PATIENTS" android:textColor="#374151" android:textSize="12sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1.2k+" android:textColor="#111827" android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PRICE" android:textColor="#374151" android:textSize="12sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rs.3500.00" android:textColor="#111827" android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_about_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="28dp"
                android:text="About Doctor"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cv_doctor" />

            <TextView
                android:id="@+id/tv_about_desc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="4dp"
                android:text="Dr. Dhammika Weerakoon is a highly experienced cardiologist specializing in non-invasive heart treatments. She completed her residency at Johns Hopkins and has been practicing for over 8 years."
                android:textColor="#374151"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_about_label" />

            <TextView
                android:id="@+id/tv_select_date_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="28dp"
                android:text="Select Date"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_about_desc" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="February 2026"
                android:textColor="#004A99"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/tv_select_date_label"
                app:layout_constraintEnd_toEndOf="parent" />

            <HorizontalScrollView
                android:id="@+id/hsv_dates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clipToPadding="false"
                android:paddingHorizontal="18dp"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/tv_select_date_label">

                <LinearLayout
                    android:id="@+id/ll_date_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Day Items -->
                    <LinearLayout
                        android:id="@+id/date_mon"
                        android:layout_width="64dp"
                        android:layout_height="84dp"
                        android:layout_margin="6dp"
                        android:background="@drawable/bg_rounded"
                        android:backgroundTint="#FFFFFF"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mon" android:textColor="#374151" android:textSize="12sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="06" android:textColor="#111827" android:textSize="20sp" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/date_tue"
                        android:layout_width="64dp"
                        android:layout_height="84dp"
                        android:layout_margin="6dp"
                        android:background="@drawable/bg_rounded"
                        android:backgroundTint="#FFFFFF"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tue" android:textColor="#374151" android:textSize="12sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="07" android:textColor="#111827" android:textSize="20sp" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/date_wed"
                        android:layout_width="64dp"
                        android:layout_height="84dp"
                        android:layout_margin="6dp"
                        android:background="@drawable/bg_rounded"
                        android:backgroundTint="#FFFFFF"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Wed" android:textColor="#374151" android:textSize="12sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="08" android:textColor="#111827" android:textSize="20sp" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/date_thu"
                        android:layout_width="64dp"
                        android:layout_height="84dp"
                        android:layout_margin="6dp"
                        android:background="@drawable/bg_rounded"
                        android:backgroundTint="#FFFFFF"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thu" android:textColor="#374151" android:textSize="12sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="09" android:textColor="#111827" android:textSize="20sp" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/date_fri"
                        android:layout_width="64dp"
                        android:layout_height="84dp"
                        android:layout_margin="6dp"
                        android:background="@drawable/bg_rounded"
                        android:backgroundTint="#FFFFFF"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fri" android:textColor="#374151" android:textSize="12sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="10" android:textColor="#111827" android:textSize="20sp" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/date_sat"
                        android:layout_width="64dp"
                        android:layout_height="84dp"
                        android:layout_margin="6dp"
                        android:background="@drawable/bg_rounded"
                        android:backgroundTint="#FFFFFF"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sat" android:textColor="#374151" android:textSize="12sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="11" android:textColor="#111827" android:textSize="20sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tv_slots_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="28dp"
                android:text="Available Slots"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/hsv_dates" />

            <!-- Slots Container -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_slots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingHorizontal="18dp"
                app:layout_constraintTop_toBottomOf="@id/tv_slots_label">

                <TextView
                    android:id="@+id/slot_0900"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_rounded"
                    android:backgroundTint="#FFFFFF"
                    android:gravity="center"
                    android:text="09:00 AM"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintEnd_toStartOf="@id/slot_1000"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/slot_1000"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_rounded"
                    android:backgroundTint="#FFFFFF"
                    android:gravity="center"
                    android:text="10:00 AM"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintEnd_toStartOf="@id/slot_1030"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toEndOf="@id/slot_0900"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/slot_1030"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_rounded"
                    android:backgroundTint="#FFFFFF"
                    android:gravity="center"
                    android:text="10:30 AM"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toEndOf="@id/slot_1000"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/slot_0100"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_margin="6dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_rounded"
                    android:backgroundTint="#FFFFFF"
                    android:gravity="center"
                    android:text="01:00 PM"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintEnd_toStartOf="@id/slot_0230"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/slot_0900" />

                <TextView
                    android:id="@+id/slot_0230"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_rounded"
                    android:backgroundTint="#FFFFFF"
                    android:gravity="center"
                    android:text="02:30 PM"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintEnd_toStartOf="@id/slot_0400"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toEndOf="@id/slot_0100"
                    app:layout_constraintTop_toTopOf="@id/slot_0100" />

                <TextView
                    android:id="@+id/slot_0400"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_rounded"
                    android:backgroundTint="#FFFFFF"
                    android:gravity="center"
                    android:text="04:00 PM"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toEndOf="@id/slot_0230"
                    app:layout_constraintTop_toTopOf="@id/slot_0100" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <Button
        android:id="@+id/btn_confirm_selection"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#007BFF"
        android:text="Confirm Selection"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>