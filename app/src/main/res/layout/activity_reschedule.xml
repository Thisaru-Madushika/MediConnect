<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EDF6FF"
    tools:context=".RescheduleActivity">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="32dp"
        android:paddingBottom="16dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/left_4"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_rounded"
            android:backgroundTint="#FFFFFF"
            android:gravity="center">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_back"
                app:tint="#000000"
                android:contentDescription="Back" />
        </LinearLayout>

        <TextView
            android:id="@+id/reschedule_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Reschedule"
            android:textColor="#000000"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginEnd="40dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/confirm_footer"
        app:layout_constraintTop_toBottomOf="@id/header_layout">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <!-- Original Appointment Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/original_card_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="22dp"
                android:background="@drawable/bg_rounded"
                android:backgroundTint="#D1E9FF"
                android:padding="20dp"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/original_appointment_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ORIGINAL APPOINTMENT"
                    android:textColor="#747474"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/dr_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Dr. Dhammika Weerakoon"
                    android:textColor="#232323"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/original_appointment_label" />

                <TextView
                    android:id="@+id/current_date_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Tue, 10 Feb 2026"
                    android:textColor="#BD000000"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/dr_name" />

                <ImageView
                    android:id="@+id/refresh_icon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_records"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#007BFF" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/change_date_time_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:text="Change Date &amp; Time"
                android:textColor="#000000"
                android:textSize="28sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/original_card_container" />

            <TextView
                android:id="@+id/subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:text="Select your new preferred timing"
                android:textColor="#747474"
                android:textSize="16sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/change_date_time_label" />

            <!-- Date Selection -->
            <TextView
                android:id="@+id/select_new_date_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:text="Select New Date"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/subtitle" />

            <TextView
                android:id="@+id/month_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="February 2026"
                android:textColor="#004A99"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/select_new_date_label"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Dates Horizontal Scroll -->
            <HorizontalScrollView
                android:id="@+id/date_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clipToPadding="false"
                android:paddingHorizontal="24dp"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/select_new_date_label">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <!-- Day Items -->
                    <LinearLayout
                        android:id="@+id/res_date_tue"
                        android:layout_width="55dp"
                        android:layout_height="75dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_rounded"
                        android:backgroundTint="#FFFFFF"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tue" android:textColor="#666666" android:textSize="11sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="07" android:textColor="#000000" android:textSize="20sp" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/res_date_wed"
                        android:layout_width="55dp"
                        android:layout_height="75dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_rounded"
                        android:backgroundTint="#FFFFFF"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Wed" android:textColor="#666666" android:textSize="11sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="08" android:textColor="#000000" android:textSize="20sp" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/res_date_thu"
                        android:layout_width="55dp"
                        android:layout_height="75dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_rounded"
                        android:backgroundTint="#FFFFFF"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thu" android:textColor="#666666" android:textSize="11sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="09" android:textColor="#000000" android:textSize="20sp" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/res_date_fri"
                        android:layout_width="55dp"
                        android:layout_height="75dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_rounded"
                        android:backgroundTint="#007BFF"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fri" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/res_date_sat"
                        android:layout_width="55dp"
                        android:layout_height="75dp"
                        android:background="@drawable/bg_rounded"
                        android:backgroundTint="#FFFFFF"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sat" android:textColor="#666666" android:textSize="11sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="11" android:textColor="#000000" android:textSize="20sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/available_slots_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:text="Available Slots"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/date_scroll" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/slots_grid_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingHorizontal="18dp"
                app:layout_constraintTop_toBottomOf="@id/available_slots_label">

                <TextView android:id="@+id/slot1" android:layout_width="0dp" android:layout_height="48dp" android:layout_margin="6dp" android:background="@drawable/bg_rounded" android:backgroundTint="#FFFFFF" android:gravity="center" android:text="09:00 AM" android:textColor="#666666" android:textSize="12sp" android:textStyle="bold" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toStartOf="@id/slot2" app:layout_constraintHorizontal_weight="1" />
                <TextView android:id="@+id/slot2" android:layout_width="0dp" android:layout_height="48dp" android:layout_margin="6dp" android:background="@drawable/bg_rounded" android:backgroundTint="#FFFFFF" android:gravity="center" android:text="10:00 AM" android:textColor="#666666" android:textSize="12sp" android:textStyle="bold" app:layout_constraintStart_toEndOf="@id/slot1" app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toStartOf="@id/slot3" app:layout_constraintHorizontal_weight="1" />
                <TextView android:id="@+id/slot3" android:layout_width="0dp" android:layout_height="48dp" android:layout_margin="6dp" android:background="@drawable/bg_rounded" android:backgroundTint="#FFFFFF" android:gravity="center" android:text="10:30 AM" android:textColor="#666666" android:textSize="12sp" android:textStyle="bold" app:layout_constraintStart_toEndOf="@id/slot2" app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintHorizontal_weight="1" />
                <TextView android:id="@+id/slot4" android:layout_width="0dp" android:layout_height="48dp" android:layout_margin="6dp" android:layout_marginTop="12dp" android:background="@drawable/bg_rounded" android:backgroundTint="#FFFFFF" android:gravity="center" android:text="01:00 PM" android:textColor="#666666" android:textSize="12sp" android:textStyle="bold" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/slot1" app:layout_constraintEnd_toStartOf="@id/slot5" app:layout_constraintHorizontal_weight="1" />
                <TextView android:id="@+id/slot5" android:layout_width="0dp" android:layout_height="48dp" android:layout_margin="6dp" android:background="@drawable/bg_rounded" android:backgroundTint="#FFFFFF" android:gravity="center" android:text="02:30 PM" android:textColor="#666666" android:textSize="12sp" android:textStyle="bold" app:layout_constraintStart_toEndOf="@id/slot4" app:layout_constraintTop_toTopOf="@id/slot4" app:layout_constraintEnd_toStartOf="@id/slot6" app:layout_constraintHorizontal_weight="1" />
                <TextView android:id="@+id/slot6" android:layout_width="0dp" android:layout_height="48dp" android:layout_margin="6dp" android:background="@drawable/bg_rounded" android:backgroundTint="#007BFF" android:gravity="center" android:text="04:00 PM" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" app:layout_constraintStart_toEndOf="@id/slot5" app:layout_constraintTop_toTopOf="@id/slot4" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintHorizontal_weight="1" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Footer Action Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/confirm_footer"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#FFFFFF"
        android:elevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_update_appointment"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="24dp"
            android:background="@drawable/bg_rounded"
            android:backgroundTint="#0069D9"
            android:text="Update Appointment"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>